{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "my-agent-starter",
  "main": "src/server.ts",
  "compatibility_date": "2026-03-02",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "ai": {
    "binding": "AI",
    "remote": true
  },
  "vars": {
    "AI_GATEWAY_ID": "my-agent-gateway"
  },
  "assets": {
    "directory": "./public",
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/agents/*",
      "/oauth/*"
    ]
  },
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    }
  },
  "durable_objects": {
    "bindings": [
      {
        "class_name": "ChatAgent",
        "name": "ChatAgent"
      }
    ]
  },
  "migrations": [
    {
      "new_sqlite_classes": [
        "ChatAgent"
      ],
      "tag": "v1"
    }
  ],
}